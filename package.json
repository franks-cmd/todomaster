{
  "name": "todomaster",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "cd frontend && npm install && cd ../backend && npm install && cd ../db && npm install",
    "db:migrate": "cd db && npx tsx migrate.ts",
    "db:seed": "cd db && npx tsx seed.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "setup": "npm run install:all && npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
